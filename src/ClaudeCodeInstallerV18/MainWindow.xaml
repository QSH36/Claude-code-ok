<Window x:Class="ClaudeCodeInstallerV18.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Code 安装器 v1.0.6" Height="640" Width="820"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#F0F2F5" FontFamily="Microsoft YaHei UI" FontSize="9pt">
    <Window.Resources>
        <SolidColorBrush x:Key="BrandBlue" Color="#0066FF"/>
        <SolidColorBrush x:Key="BrandEnd" Color="#4DA3FF"/>
        <SolidColorBrush x:Key="Green" Color="#00B84D"/>
        <SolidColorBrush x:Key="Orange" Color="#FF6B35"/>
        <SolidColorBrush x:Key="Red" Color="#EF4444"/>
        <SolidColorBrush x:Key="CardBg" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="TextDark" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="TextGray" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="#1E1E2E">
            <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#FF5F57" Margin="0,0,6,0"/>
                <Ellipse Width="10" Height="10" Fill="#FFBD2E" Margin="0,0,6,0"/>
                <Ellipse Width="10" Height="10" Fill="#28CA41"/>
                <TextBlock Text="Claude Code Installer v1.0.6 — Shimizu" Foreground="#CCCCCC" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Page Content -->
        <ContentControl Grid.Row="1" x:Name="PageHost"/>

        <!-- Nav Bar -->
        <Grid Grid.Row="2" x:Name="NavBar" Visibility="Collapsed">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1E1E2E" Offset="0"/>
                    <GradientStop Color="#16162A" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Button x:Name="BtnBack" Content="← 上一步" Width="95" Height="32"
                        Background="rgba(255,255,255,0.1)" Foreground="#CCCCCC" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="OnBack"/>
                <Button x:Name="BtnNext" Content="下一步 →" Width="110" Height="32" Margin="12,0,0,0"
                        Background="#0066FF" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="OnNext"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
